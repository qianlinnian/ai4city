# 复制为 .env 后填入真实密钥；不填则自动进入 MOCK 演示模式

# 本机数据根目录（含 assets、filled_metrics.xlsx、分析图目录）
DATA_DIR=D:\GitHubZY\ai4city
LOAD_DATA_DIR=assets

# LangChain + OpenAI 兼容多模态 LLM（翻译官 / 制图员；无 Key 时走规则/RAG）
# 国内推荐：阿里云百炼。质量优先 qwen3.7-plus；稳定后可改 qwen3.6-flash 降低成本。
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.7-plus

# 也兼容已有的百炼变量写法；若 LLM_API_KEY 为空而 QWEN_API_KEY 非空，将自动使用下列配置。
# QWEN_API_KEY=
# QWEN_OPENAI_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen3.7-plus

# World Labs Marble API（可选；当前编排默认走 Seedream）
WORLDLABS_API_KEY=
WORLDLABS_BASE_URL=https://api.worldlabs.ai
WORLDLABS_MODEL=marble-1.1

# 运行模式：auto | mock | live
# auto = 有密钥用 live，无密钥用 mock
RUN_MODE=auto

# 后端只读项目数据目录（原始 Excel 和全景图不在网页上传，也不会被代码改写）
AI4CITY_DATA_DIR=D:\course\ai4city-data
# AI4CITY_PANORAMA_DIR=D:\course\ai4city-data
# AI4CITY_METRICS_TABLE_DIR=D:\course\ai4city-data
AI4CITY_KNOWLEDGE_DIR=D:\course\ai4city-data\knowledge

# Task 2/3 全景多视图。派生图写入项目 outputs/panorama_views，不写入数据目录。
PANORAMA_OVERVIEW_WIDTH=2048
PANORAMA_OVERVIEW_HEIGHT=1024
PANORAMA_PERSPECTIVE_WIDTH=1024
PANORAMA_PERSPECTIVE_HEIGHT=1024
PANORAMA_PERSPECTIVE_FOV=90
PANORAMA_HORIZONTAL_YAWS=0,90,180,270
# 迭代中：向下观察视图代码保留，当前 Task 2/3 链路固定不调用。
# PANORAMA_INCLUDE_DOWNWARD=false
PANORAMA_DOWNWARD_PITCH=-20
PANORAMA_ASPECT_TOLERANCE=0.01
PANORAMA_STRICT_ASPECT=true
SCENE_UNDERSTANDING_ENABLED=false

# RAG：auto 会在有 Qwen Key 时优先使用远程 Embedding，否则回退本地 TF-IDF。
# tfidf 始终本地离线；qwen_embedding 强制优先使用 text-embedding-v4，失败后默认回退。
RAG_ENABLED=false
RAG_RETRIEVAL_MODE=auto
RAG_TOP_K=4
RAG_MIN_SCORE=0.05
RAG_INCLUDE_REPOSITORY_SOURCES=true
# RAG_CACHE_DIR=D:\course\ai4city\outputs\rag_cache
# RAG_EMBEDDING_API_KEY=             # 留空时复用 LLM_API_KEY / QWEN_API_KEY
# RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_EMBEDDING_MODEL=text-embedding-v4
RAG_EMBEDDING_DIMENSIONS=1024
RAG_EMBEDDING_BATCH_SIZE=10
RAG_EMBEDDING_TIMEOUT=30
RAG_EMBEDDING_FALLBACK_TO_TFIDF=true

# 生成后自动复算七项形态指标（复用 morph_metrics_extractor.py，不改原图）。
# 默认使用本地 SegFormer 缓存；模型未缓存时不会静默下载，而是显示明确错误。
POST_EDIT_METRICS_ENABLED=true
POST_EDIT_METRICS_MODEL_PROFILE=segformer-b2-ade20k
POST_EDIT_METRICS_DEVICE=auto
POST_EDIT_METRICS_ALLOW_MODEL_DOWNLOAD=false
# POST_EDIT_METRICS_OUTPUT_DIR=D:\course\ai4city\outputs\post_edit_metrics

# DeepSeek 离线知识整理器。只有 scripts/build_curated_knowledge.py --execute 会调用。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
# 结构化知识抽取默认关闭思考模式，避免思考 tokens 挤占 JSON 输出额度。
DEEPSEEK_KNOWLEDGE_THINKING=false
DEEPSEEK_KNOWLEDGE_MAX_TOKENS=16000
# KNOWLEDGE_DRAFT_DIR=D:\course\ai4city\outputs\knowledge_drafts
# 正式发布知识库；RAG 只读取其中 published 子目录，不读取草稿。
# RAG_KNOWLEDGE_DIR=D:\course\ai4city\rag_knowledge

# 豆包 Seedream 5.0 Pro（火山方舟 · 图生图，推荐用于全景改造）
# 密钥在火山方舟控制台创建：https://console.volcengine.com/ark
SEEDREAM_API_KEY=
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com
SEEDREAM_MODEL=doubao-seedream-5-0-pro-260628
# lite 可改: doubao-seedream-5-0-260128
# 输出尺寸：Pro 常用 1K/2K；也可 2048x1024 / auto
SEEDREAM_SIZE=2K
SEEDREAM_RESPONSE_FORMAT=url
SEEDREAM_WATERMARK=false

# Linux / ECS 示例：DATA_DIR=/opt/ai4city
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
