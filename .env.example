# 复制为 .env 后填入真实密钥；不填则自动进入 MOCK 演示模式

# OpenAI 兼容 LLM（翻译官 / 制图员 / 提示词专家 可选调用）
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# World Labs Marble API（Pano Edit / 全景生成）
WORLDLABS_API_KEY=
WORLDLABS_BASE_URL=https://api.worldlabs.ai

# 运行模式：auto | mock | live
# auto = 有密钥用 live，无密钥用 mock
RUN_MODE=auto
