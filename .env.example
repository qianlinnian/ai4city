AI4CITY_CONFIG=configs/default.yaml
AI4CITY_RUNS_DIR=runs

# OpenAI-compatible multimodal endpoint (optional; mock adapters are default).
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=local-model
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# Never commit real participant identifiers or API keys.
AI4CITY_DATA_MODE=deidentified
LANGSMITH_TRACING=false
